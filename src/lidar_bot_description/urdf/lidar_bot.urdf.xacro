<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="basic_robot">

    <xacro:property name="base_mass" value="1.00"/>
    <xacro:property name="base_radius" value=".150"/>
    <xacro:property name="base_thickness" value=".050"/>
    
    <xacro:property name="wheel_mass" value="0.10"/>
    <xacro:property name="turtle_wheel_radius" value=".050"/>
    <xacro:property name="turtle_wheel_length" value=".015"/>
    
    <xacro:property name="caster_mass" value="0.001"/>
    <xacro:property name="caster_radius" value="${(turtle_wheel_radius-base_thickness/2.0)/2.0}"/>

    <xacro:property name="lidar_mass" value="0.001"/>
    <xacro:property name="lidar_length" value="0.01"/>
    <xacro:property name="lidar_radius" value="0.01"/>
    

    <link name="base_link">
        <visual>
            <geometry>
                <cylinder length="${base_thickness}" radius="${base_radius}"/>
            </geometry>
            <material name="green">
                <color rgba="0.2 1.0 0.2 1"/>
            </material>
        </visual>
        <collision>
                <geometry>
                    <cylinder length="${base_thickness}" radius="${base_radius}"/>
                </geometry>
        </collision>
        <inertial>
            <mass value="${base_mass}"/>
            <inertia 
                ixx="${(1.0/12.0) * base_mass * (3*base_radius*base_radius + base_thickness*base_thickness)}"
                iyy="${(1.0/12.0) * base_mass * (3*base_radius*base_radius + base_thickness*base_thickness)}"
                izz="${0.5 * base_mass * base_radius*base_radius}"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder length="${turtle_wheel_length}" radius="${turtle_wheel_radius}"/>
            </geometry>
        </visual>
        <collision>
                <geometry>
                    <cylinder length="${turtle_wheel_length}" radius="${turtle_wheel_radius}"/>
                </geometry>
        </collision>
        <inertial>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="${(1.0/12.0) * wheel_mass * (3*turtle_wheel_radius*turtle_wheel_radius + turtle_wheel_length*turtle_wheel_length)}"
                iyy="${(1.0/12.0) * wheel_mass * (3*turtle_wheel_radius*turtle_wheel_radius + turtle_wheel_length*turtle_wheel_length)}"
                izz="${0.5 * wheel_mass * turtle_wheel_radius*turtle_wheel_radius}"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder length="${turtle_wheel_length}" radius="${turtle_wheel_radius}"/>
            </geometry>
        </visual>
        <collision>
                <geometry>
                    <cylinder length="${turtle_wheel_length}" radius="${turtle_wheel_radius}"/>
                </geometry>
        </collision>
        <inertial>
            <mass value="${wheel_mass}"/>
            <inertia
                ixx="${(1.0/12.0) * wheel_mass * (3*turtle_wheel_radius*turtle_wheel_radius + turtle_wheel_length*turtle_wheel_length)}"
                iyy="${(1.0/12.0) * wheel_mass * (3*turtle_wheel_radius*turtle_wheel_radius + turtle_wheel_length*turtle_wheel_length)}"
                izz="${0.5 * wheel_mass * turtle_wheel_radius*turtle_wheel_radius}"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <link name="caster_wheel_front">
        <visual>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
        </visual>
        <collision>
                <geometry>
                    <sphere radius="${caster_radius}"/>
                </geometry>
        </collision>
        <inertial>
            <mass value="${caster_mass}"/>
            <inertia
                ixx="${(2.0/5.0) * caster_mass * (caster_radius)*(caster_radius)}"
                iyy="${(2.0/5.0) * caster_mass * (caster_radius)*(caster_radius)}"
                izz="${(2.0/5.0) * caster_mass * (caster_radius)*(caster_radius)}"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <link name="caster_wheel_back">
        <visual>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
        </visual>
        <collision>
                <geometry>
                    <sphere radius="${caster_radius}"/>
                </geometry>
        </collision>
        <inertial>
            <mass value="${caster_mass}"/>
            <inertia
                ixx="${(2.0/5.0) * caster_mass * (caster_radius)*(caster_radius)}"
                iyy="${(2.0/5.0) * caster_mass * (caster_radius)*(caster_radius)}"
                izz="${(2.0/5.0) * caster_mass * (caster_radius)*(caster_radius)}"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <link name="lidar">
        <visual>
            <geometry>
                <cylinder length="${lidar_length}" radius="${lidar_radius}"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="${lidar_length}" radius="${lidar_radius}"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="${lidar_mass}"/>
            <inertia
                ixx="${(1.0/12.0) * lidar_mass * (3*lidar_radius*lidar_radius + lidar_length*lidar_length)}"
                iyy="${(1.0/12.0) * lidar_mass * (3*lidar_radius*lidar_radius + lidar_length*lidar_length)}"
                izz="${0.5 * lidar_mass * lidar_radius*lidar_radius}"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <link name="base_footprint"/>

    <joint name="footprint_base" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${base_thickness}" rpy="0 0 0"/>
    </joint>

    <joint name="base_left_wheel" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 ${base_radius+turtle_wheel_length/2} 0" rpy="1.57075 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <joint name="base_right_wheel" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz ="0 -${base_radius+turtle_wheel_length/2} 0" rpy="1.57075 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <joint name="base_caster_wheel_front" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_front"/>
        <origin xyz ="${base_radius-(base_radius/4)} 0 -${base_thickness/2.0+caster_radius}" rpy="0 0 0"/>
    </joint>

    <joint name="base_caster_wheel_back" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_back"/>
        <origin xyz ="-${base_radius-(base_radius/4)} 0 -${base_thickness/2.0+caster_radius}" rpy="0 0 0"/>
    </joint>

    <joint name="base_lidar" type="fixed">
        <parent link="base_link"/>
        <child link="lidar"/>
        <origin xyz="${base_radius-lidar_radius} 0 ${base_thickness/2.0+lidar_length/2.0}"/>
        <axis xyz="0 1 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="caster_wheel_front">
        <mu1 value="0.1"/>
        <mu2 value="0.1"/>
    </gazebo>

    <gazebo reference="caster_wheel_back">
        <mu1 value="0.1"/>
        <mu2 value="0.1"/>
    </gazebo>

    <gazebo>
        <plugin
            filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">

            <!-- wheel parameters -->
            <left_joint>base_left_wheel</left_joint>
            <right_joint>base_right_wheel</right_joint>

            <!-- kinematics -->
            <wheel_separation>${base_radius*2.0+turtle_wheel_length}</wheel_separation>
            <wheel_radius>${turtle_wheel_radius}</wheel_radius>

            <!-- output -->
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin
            filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">

            <!-- Which joints to get published in Gazebo -->
            <joint_name>base_left_wheel</joint_name>
            <joint_name>base_right_wheel</joint_name>
        </plugin>
    </gazebo>

    <gazebo reference="lidar">
        <sensor name="gpu_lidar" type="gpu_lidar">
            <pose relative_to="lidar">0 0 0 0 0 0</pose>
            <topic>lidar</topic>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>640</samples>
                        <resolution>1</resolution>
                        <min_angle>-1.396263</min_angle>
                        <max_angle>1.396263</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>1</samples>
                        <resolution>0.01</resolution>
                        <min_angle>0</min_angle>
                        <max_angle>0</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.08</min>
                    <max>10.0</max>
                    <resolution>0.01</resolution>
                </range>
            </ray>
            <always_on>1</always_on>
            <visualize>true</visualize>
        </sensor>
    </gazebo>
</robot>